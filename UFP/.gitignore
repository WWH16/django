# =======================
# Django-Specific Ignores
# =======================
*.pot
*.pyc
__pycache__/
local_settings.py
media/
static/
staticfiles/
*/migrations/__pycache__/
*/migrations/*.pyc

# =======================
# Python General Ignores
# =======================
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.installed.cfg
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# =======================
# Virtual Environment
# =======================
env/
venv/
ENV/
myenv/
.venv/
.env
.env.*

# =======================
# IDE / Editor / OS Junk
# =======================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# =======================
# Logs
# =======================
*.log
logs/

# =======================
# PostgreSQL (Optional)
# =======================
*.sql
*.dump
*.backup
*.pgsql
.pgdata/
.psql_history
